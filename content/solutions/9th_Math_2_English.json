      "steps": [
        {"text": "For 30 degrees: sin 30 = 1/2, cos 30 = sqrt(3)/2, tan 30 = 1/sqrt(3).", "latex": "\\sin 30^\\circ = \\tfrac{1}{2},\\; \\cos 30^\\circ = \\tfrac{\\sqrt{3}}{2},\\; \\tan 30^\\circ = \\tfrac{1}{\\sqrt{3}}"},
        {"text": "For 60 degrees: sin 60 = sqrt(3)/2, cos 60 = 1/2, tan 60 = sqrt(3).", "latex": "\\sin 60^\\circ = \\tfrac{\\sqrt{3}}{2},\\; \\cos 60^\\circ = \\tfrac{1}{2},\\; \\tan 60^\\circ = \\sqrt{3}"},
        {"text": "For 45 degrees: sin 45 = cos 45 = 1/sqrt(2), tan 45 = 1.", "latex": "\\sin 45^\\circ = \\cos 45^\\circ = \\tfrac{1}{\\sqrt{2}},\\; \\tan 45^\\circ = 1"},
        {"text": "For 0 degrees: sin 0 = 0, cos 0 = 1, tan 0 = 0. For 90 degrees: sin 90 = 1, cos 90 = 0, and tan 90 is undefined.", "latex": "\\sin 0^\\circ = 0,\\; \\cos 0^\\circ = 1,\\; \\sin 90^\\circ = 1,\\; \\cos 90^\\circ = 0"}
      ]
